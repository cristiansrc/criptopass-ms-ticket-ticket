# ==========================================
# CriptoPass MS Ticket Ticket - Environment
# ==========================================
# Copiar este archivo a .env y ajustar los valores
# cp .env.example .env

# ------------------------------------------
# Spring Boot
# ------------------------------------------
# Perfil activo: dev, staging, prod
SPRING_PROFILES_ACTIVE=dev

# Puerto del servidor
SERVER_PORT=8084

# ------------------------------------------
# Base de Datos (PostgreSQL)
# ------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ticket_db
DB_USERNAME=ticket_user
DB_PASSWORD=devpass

# Pool de conexiones (HikariCP)
DB_POOL_SIZE=20
DB_POOL_MIN_IDLE=5
DB_CONNECTION_TIMEOUT=30000

# Flyway - Migraciones
FLYWAY_ENABLED=true
FLYWAY_LOCATIONS=classpath:db/migration
FLYWAY_BASELINE_ON_MIGRATE=true

# ------------------------------------------
# Keycloak - Autenticación OAuth2/OIDC
# ------------------------------------------
# URL base del realm de Keycloak
KEYCLOAK_ISSUER_URI=http://localhost:8081/realms/criptopass

# Client registrado en Keycloak
KEYCLOAK_CLIENT_ID=ms-ticket-ticket
KEYCLOAK_CLIENT_SECRET=<client-secret-from-keycloak>

# Roles esperados en el token JWT
KEYCLOAK_ROLES_CLAIM=resource_access.${KEYCLOAK_CLIENT_ID}.roles

# ------------------------------------------
# Servicios Externos
# ------------------------------------------
# Payment Service
PAYMENT_SERVICE_URL=http://localhost:8085
PAYMENT_SERVICE_TIMEOUT=5000

# Event Service
EVENT_SERVICE_URL=http://localhost:8083
EVENT_SERVICE_TIMEOUT=3000

# Blockchain Service
BLOCKCHAIN_SERVICE_URL=http://localhost:8086
BLOCKCHAIN_SERVICE_TIMEOUT=10000
BLOCKCHAIN_NETWORK=testnet

# ------------------------------------------
# Redis (Cache)
# ------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_TTL=300

# ------------------------------------------
# API Gateway
# ------------------------------------------
# Path base expuesto por el gateway
GATEWAY_BASE_PATH=/ms-ticket-ticket/v1

# ------------------------------------------
# Logging
# ------------------------------------------
LOG_LEVEL=DEBUG
LOG_FORMAT=console
# LOG_FORMAT=json  # Usar en staging/prod

# ------------------------------------------
# Actuator / Observabilidad
# ------------------------------------------
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE=health,info,metrics,prometheus
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always

# ------------------------------------------
# QR Code
# ------------------------------------------
# TTL del QR code en minutos
QR_CODE_TTL_MINUTES=5
# Secret para firmar QR codes
QR_CODE_SECRET=<random-secret-for-qr-signing>

# ------------------------------------------
# Compra de Boletas
# ------------------------------------------
# Timeout para pago pendiente en minutos
PAYMENT_TIMEOUT_MINUTES=15
# Máximo de boletas por compra
MAX_TICKETS_PER_PURCHASE=10
